<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Mythic Menagerie - Prototype (Phaser)</title>
    <script src="https://cdn.jsdelivr.net/npm/phaser@3.55.2/dist/phaser.min.js"></script>
    <style>body { margin:0; background:#000; } canvas { display:block; margin:0 auto; }</style>
</head>
<body>
<script>
// ==================== CREATURE GENERATION (EXACTLY 1,275 uniques) ====================
const speciesList = ["Dragon","Phoenix","Unicorn","Griffin","Wolf","Eagle","Shark","Serpent","Bear","Lion","Tiger","Fox","Owl","Bat","Turtle","Spider","Octopus"];
const dietList = ["Herbivore","Carnivore","Omnivore","Insectivore","Scavenger"];
const habitatList = ["Forest","Desert","Ocean"];
const coveringList = ["Fur","Scales","Feathers","Skin","Exoskeleton"];
const coveringColors = [0x8B4513, 0x4682B4, 0xFFD700, 0xF5F5DC, 0x4B0082];

function getCreatureDescription(id) {
    if (id < 0 || id > 1274) return "Unknown Creature";
    let temp = id;
    const speciesIdx = temp % 17;
    temp = Math.floor(temp / 17);
    const dietIdx = temp % 5;
    temp = Math.floor(temp / 5);
    const habitatIdx = temp % 3;
    temp = Math.floor(temp / 3);
    const coveringIdx = temp % 5;

    return {
        id: id,
        name: `\( {speciesList[speciesIdx]} # \){id}`,
        desc: `A majestic ${coveringList[coveringIdx].toLowerCase()}-covered ${speciesList[speciesIdx].toLowerCase()} from the ${habitatList[habitatIdx].toLowerCase()} habitat. ` +
              `It is a ${dietList[dietIdx].toLowerCase()} with glowing eyes, sharp teeth, and powerful claws. Age: Adult.`
    };
}

// ==================== PHASER GAME ====================
const config = {
    type: Phaser.AUTO,
    width: 800,
    height: 600,
    physics: { default: 'arcade', arcade: { debug: false } },
    scene: { preload: preload, create: create, update: update }
};

let game = new Phaser.Game(config);
let player, creatures = [], cursors, collected = 0, collectedText, descText, worldWidth = 6000, worldHeight = 6000;

function preload() {
    // No external assets needed for prototype
}

function create() {
    // Background
    this.add.rectangle(0, 0, worldWidth, worldHeight, 0x228B22).setOrigin(0);

    // Player (green rectangle)
    const playerRect = this.add.rectangle(400, 300, 32, 32, 0x00ff00);
    player = this.physics.add.existing(playerRect, false);
    player.body.setCollideWorldBounds(true);
    this.cameras.main.setBounds(0, 0, worldWidth, worldHeight);
    this.cameras.main.startFollow(player);

    // UI
    collectedText = this.add.text(10, 10, "Collected: 0 / 1275", { fontSize: '20px', color: '#fff', backgroundColor: '#000' }).setScrollFactor(0);
    descText = this.add.text(10, 50, "", { fontSize: '18px', color: '#ffff00', backgroundColor: '#000000aa', padding: { x: 10, y: 5 } }).setScrollFactor(0);
    descText.setVisible(false);

    // Controls
    cursors = this.input.keyboard.createCursorKeys();

    // Spawn 50 creatures
    for (let i = 0; i < 50; i++) {
        const id = Math.floor(Math.random() * 1275);
        const x = Phaser.Math.Between(50, worldWidth - 50);
        const y = Phaser.Math.Between(50, worldHeight - 50);
        spawnCreature(this, x, y, id);
    }

    // Touch/Click to move (mobile + desktop friendly)
    this.input.on('pointerdown', (pointer) => {
        this.targetX = pointer.worldX;
        this.targetY = pointer.worldY;
    });
}

function spawnCreature(scene, x, y, id) {
    const info = getCreatureDescription(id);
    const coveringIdx = Math.floor(id / (17 * 5 * 3)) % 5;
    const color = coveringColors[coveringIdx];

    const rect = scene.add.rectangle(x, y, 40, 40, color);
    rect.setData('id', id);
    rect.setData('info', info);
    creatures.push(rect);
}

function collectCreature(creature) {
    const info = creature.getData('info');
    descText.setText(`\( {info.name}\n \){info.desc}`);
    descText.setVisible(true);
    this.time.delayedCall(3000, () => descText.setVisible(false));

    collected++;
    collectedText.setText(`Collected: ${collected} / 1275`);

    // Remove from world
    creature.destroy();
    const index = creatures.indexOf(creature);
    if (index > -1) creatures.splice(index, 1);
}

function update() {
    const speed = 200;
    player.body.setVelocity(0);

    // Keyboard
    if (cursors.left.isDown) player.body.setVelocityX(-speed);
    else if (cursors.right.isDown) player.body.setVelocityX(speed);
    if (cursors.up.isDown) player.body.setVelocityY(-speed);
    else if (cursors.down.isDown) player.body.setVelocityY(speed);

    // Pointer / Touch movement
    if (this.targetX !== undefined) {
        const dx = this.targetX - player.x;
        const dy = this.targetY - player.y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist > 10) {
            player.body.setVelocity((dx/dist) * speed, (dy/dist) * speed);
        } else {
            this.targetX = undefined;
        }
    }

    // Simple collection (distance check - no physics needed)
    for (let i = creatures.length - 1; i >= 0; i--) {
        const cr = creatures[i];
        if (Phaser.Math.Distance.Between(player.x, player.y, cr.x, cr.y) < 40) {
            collectCreature.call(this, cr);
        }
    }
}
</script>
</body>
</html>
